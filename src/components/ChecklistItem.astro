---
// src/components/ChecklistItem.astro
interface Props {
  id?: string;
  note?: string;
}

const { id: idProp, note } = Astro.props;
const id = idProp ?? `checklist-${Math.random().toString(36).slice(2, 11)}`;
const maskId = `mask-${id}`;
---

<li class="checklist-item">
  <input class="checklist-item__input" type="checkbox" id={id} />
  <label class="checklist-item__label" for={id}>
    <span class="checklist-item__box" aria-hidden="true">
      <svg
        class="checklist-item__mark"
        width="29"
        height="24"
        viewBox="0 0 39 34"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        focusable="false"
      >
        <mask
          id={maskId}
          style="mask-type:luminance"
          maskUnits="userSpaceOnUse"
          x="0"
          y="0"
          width="39"
          height="34"
        >
          <path
            d="M0.570316 33.257H38.367V0.785156L0.570312 0.785159L0.570316 33.257Z"
            fill="white"></path>
        </mask>
        <g mask={`url(#${maskId})`}>
          <path
            d="M0.766488 27.0081C0.45665 27.5271 0.508814 28.1155 0.780194 28.6039C0.703751 29.1597 0.873076 29.7239 1.48528 30.1568C2.05535 30.5596 2.62532 30.9627 3.19501 31.3657C4.19691 32.0739 5.76567 32.2974 6.74006 31.3657C11.166 27.1343 15.7945 23.0866 20.5926 19.1864C24.1598 22.0492 27.7703 24.8733 31.355 27.701C32.6131 28.6937 34.4342 28.3822 35.2257 27.1996C36.3787 26.7079 37.3132 26.067 38.086 24.9731C38.454 24.4519 38.4253 23.7939 38.086 23.2709C35.7718 19.7062 31.2987 16.5721 27.6209 13.6879C28.1131 13.3094 28.6015 12.9274 29.1036 12.5569C34.0586 8.90117 37.4009 6.5817 31.2 2.83339C31.1164 2.78281 31.0311 2.79402 30.9462 2.76447C30.8273 2.71738 30.7134 2.68418 30.5816 2.66559C30.5407 2.66421 30.5024 2.65828 30.4621 2.66104C30.3345 2.65211 30.2096 2.62419 30.0802 2.64602C26.7465 3.20755 23.6461 5.452 20.8333 7.9236C18.0931 5.60324 15.1753 3.38647 11.9669 2.07111C11.2031 1.75784 10.2924 1.94041 9.70425 2.37854C8.71814 2.31457 7.81906 2.84102 7.36786 3.59753C7.30105 3.63301 7.25797 3.6533 7.18559 3.69219C5.75196 4.46161 5.621 5.99396 6.68176 7.05019C9.07722 9.43501 11.6236 11.702 14.2193 13.9288C9.54552 17.8523 3.70952 22.0837 0.766488 27.0081Z"
            fill="currentColor"></path>
        </g>
      </svg>
    </span>
    <span class="checklist-item__text">
      <slot />
      {note && <span class="checklist-item__note" set:html={note} />}
    </span>
  </label>
</li>

<script>
  const checkboxes = document.querySelectorAll(".checklist-item input");
  checkboxes.forEach((cb) => {
    const key = `checklist-${cb.id}`;
    cb.checked = localStorage.getItem(key) === "true";
    cb.addEventListener("change", () => {
      localStorage.setItem(key, cb.checked);
    });
  });
</script>

<style>
  @scope (.checklist-item) {
    :scope {
      list-style: none;
    }

    .checklist-item__input {
      position: absolute;
      opacity: 0;
      width: 0;
      height: 0;
      pointer-events: none;
    }

    .checklist-item__label {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      cursor: pointer;
      user-select: none;
    }

    .checklist-item__box {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      margin-top: 2px;
      border: 1.5px solid var(--color-border, #e8e3dc);
      background: white;
      display: flex;
      align-items: center;
      justify-content: center;
      transition:
        background 0.15s ease,
        border-color 0.15s ease;
    }

    .checklist-item__input:focus-visible
      ~ .checklist-item__label
      .checklist-item__box {
      outline: 2px solid rgb(from var(--feature-color) r g b / 0.5);
      outline-offset: 2px;
    }

    .checklist-item__input:checked
      ~ .checklist-item__label
      .checklist-item__box {
      background: rgb(from var(--feature-color) r g b / 0.5);
      border-color: rgb(from var(--feature-color) r g b / 0.85);
    }

    .checklist-item__mark {
      width: 11px;
      height: auto;
      color: var(--color-dark);
      opacity: 0;
      transform: scale(0.5) rotate(-10deg);
      transition:
        opacity 0.2s ease,
        transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .checklist-item__input:checked
      ~ .checklist-item__label
      .checklist-item__mark {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }

    .checklist-item__text {
      color: var(--color-ink, #1a1814);
    }

    .checklist-item__input:checked
      ~ .checklist-item__label
      .checklist-item__text {
      color: var(--color-ink-faint, #a8a29d);
      text-decoration: line-through;
      text-decoration-color: var(--color-dark, #e8e3dc);
    }

    .checklist-item__note {
      display: block;
      font-size: 0.75rem;
      color: var(--color-ink-faint, #a8a29d);
      margin-top: 0.2rem;
      font-weight: 300;
      line-height: 1.45;
    }

    .checklist-item__input:checked
      ~ .checklist-item__label
      .checklist-item__note {
      opacity: 0.5;
    }
  }
</style>
