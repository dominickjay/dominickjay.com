---

<div id="cur" aria-hidden="true"></div>

<script is:inline>
	const cursor = document.getElementById("cur");
	const canHover = window.matchMedia("(hover: hover)").matches;

	if (cursor && canHover) {

    const largeTargets = "a, button, .item, .big-link, .home-link";
    const smallTargets = ".prose, .intro";

    document.addEventListener(
      "pointermove",
      (event) => {
      	cursor.style.transform = `translate(${event.clientX}px, ${event.clientY}px) translate(-50%, -50%)`;

        const target = event.target instanceof Element ? event.target : null;
        const isLarge = !!target?.closest(largeTargets);
        const isSmall = !isLarge && !!target?.closest(smallTargets);

        document.body.classList.toggle("cur-lg", isLarge);
        document.body.classList.toggle("cur-sm", isSmall);
      },
      { passive: true },
    );

    document.addEventListener("pointerleave", () => {
      document.body.classList.remove("cur-lg", "cur-sm");
    });
  }
</script>
