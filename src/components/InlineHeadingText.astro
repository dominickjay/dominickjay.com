---
/** @type {{ heading: string; text: string; italicIndices?: number[] }} */
const { heading, text, italicIndices = [] } = Astro.props;

/** @type {Array<{ text: string; italic: boolean }>} */
const words = heading.split(/\s+/).map((word: string, i: number) => ({
  text: word,
  italic: italicIndices.includes(i),
}));
---

<div class="inline-heading-text">
	<h1
		id="headingTagline"
		class="heading-tagline"
	>
	  {
	   words.map((w: { text: string; italic: boolean }, i: number) => (
	      <>
	        <span
	          class:list={["sw", w.italic && "sw--highlight"]}
	        >
	          {w.text}
	        </span>
	        {i < words.length - 1 ? " " : ""}
	      </>
	    ))
	  }
	</h1>

	<h2 class="intro">
	  {text}
	</h2>
</div>
