---
import FormattedDate from "../components/FormattedDate.astro";
import FeatureListItem from "../components/FeatureListItem.astro";
import BigLink from "../components/BigLink.astro";

const { evergreen, growing, seedling } = Astro.props;
---

<div class="growth-panel flow">
  <h2 class="sr-only">My Digital Garden</h2>
  <div
    class="growth-panel__content flex flex-col justify-center gap-[32px] md:gap-[32px]"
  >
    <div class="flex flex-col gap-[32px] md:gap-[64px]">
      <div
        class="growth-panel__item flow flex flex-col"
        style="--flow-space: var(--space-l);"
      >
        <div class="max-md:flex-col flex justify-between gap-[var(--space-s)]">
          <div
            class="flex flex-col justify-between gap-[var(--space-s)] max-w-[768px] text-balance"
          >
            <h3 class="h3">Evergreen (Stable Knowledge)</h3>
            <div class="body">
            Stable and fully realised. These posts reflect current best practice and aren't likely to need significant updates.
            </div>
          </div>
          <BigLink
            href={`/writing?growth=evergreen`}
            text="See all evergreen posts"
          />
        </div>
        <ol
          class="post-list feature-list max-md:mx-[-16px] mt-[var(--space-m)]"
        >
          {
            evergreen
              .slice(0, 5)
              .map((post: any, i: number) => (
                <FeatureListItem
                  i={String(i + 1).padStart(2, "0")}
                  title={post.data.title}
                  description={post.data.description}
                  tags={post.data.tags}
                  pubDate={post.data.pubDate}
                  lastModified={post.lastModified}
                  id={post.id}
                  theme="narrow"
                />
              ))
          }
        </ol>
      </div>
      <div
        class="growth-panel__item flow flex flex-col"
        style="--flow-space: var(--space-l);"
      >
        <div class="max-md:flex-col flex justify-between gap-[var(--space-s)]">
          <div
            class="flex flex-col justify-between gap-[var(--space-s)] max-w-[768px] text-balance"
          >
            <h3 class="h3">Growing (Under Active Cultivation)</h3>
            <div class="body">
            Complete enough to be useful, but still being refined — whether that's a spec still moving, a demo still being built, or a section still to be written.
            </div>
          </div>
          <BigLink
            href={`/writing?growth=growing`}
            text="See all growing posts"
          />
        </div>
        <ol
          class="post-list feature-list max-md:mx-[-16px] mt-[var(--space-m)]"
        >
          {
            growing
              .slice(0, 5)
              .map((post: any, i: number) => (
                <FeatureListItem
                  i={String(i + 1).padStart(2, "0")}
                  title={post.data.title}
                  description={post.data.description}
                  tags={post.data.tags}
                  pubDate={post.data.pubDate}
                  lastModified={post.lastModified}
                  id={post.id}
                  theme="narrow"
                />
              ))
          }
        </ol>
      </div>
      <div
        class="growth-panel__item flow flex flex-col"
        style="--flow-space: var(--space-l);"
      >
        <div class="max-md:flex-col flex justify-between gap-[var(--space-s)]">
          <div
            class="flex flex-col justify-between gap-[var(--space-s)] max-w-[768px] text-balance"
          >
            <h3 class="h3">Seedlings (Future Research)</h3>
            <div class="body">
            Newly published or still finding their shape. Worth reading, but expect rough edges.
            </div>
          </div>
          <BigLink
            href={`/writing?growth=seedling`}
            text="See all seedling posts"
          />
        </div>
        <ol
          class="post-list feature-list max-md:mx-[-16px] mt-[var(--space-m)]"
        >
          {
            seedling
              .slice(0, 5)
              .map((post: any, i: number) => (
                <FeatureListItem
                  i={String(i + 1).padStart(2, "0")}
                  title={post.data.title}
                  description={post.data.description}
                  tags={post.data.tags}
                  pubDate={post.data.pubDate}
                  lastModified={post.lastModified}
                  id={post.id}
                  theme="narrow"
                />
              ))
          }
        </ol>
      </div>
    </div>
  </div>
</div>
