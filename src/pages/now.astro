        <div class="last-updated" data-scramble-on-load>
          <span data-scramble=`Last updated: ${lastUpdateFormatted}` aria-hidden="true" />
          <span class="sr-only">
            Last updated:
            <time datetime={lastUpdateFormatted}>{lastUpdateFormatted}</time>
          </span>
        </div>
        )}
      </div>
    </header>

    <div class="now-layout sidebar" data-reversed>

