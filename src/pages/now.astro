              <span class="past-entry__trigger-left">
                <span class="past-entry__date">
                  {post.data.pubDate.toLocaleDateString("en-GB", {
                    month: "short",
                    year: "numeric",
                  })}
                </span>
                <span class="past-entry__excerpt">{excerpt}</span>
              </span>
              <svg
                class="past-entry__icon"
                viewBox="0 0 16 16"
                fill="none"
                aria-hidden="true"
              >
                <line
                  x1="8"
                  y1="2"
                  x2="8"
                  y2="14"
                  stroke="currentColor"
                  stroke-width="1.5"
