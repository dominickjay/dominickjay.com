---
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=300, s-maxage=86400",
);

import { sanityClient } from "sanity:client";

import Layout from "../layouts/Default.astro";
import { getTopTracks } from "../lib/lastfm";
import { getCollection, render } from "astro:content";
import ScrollHeading from "../components/ScrollHeading.astro";

let nowPosts: Awaited<ReturnType<typeof getCollection<"now">>> = [];

if (import.meta.env.ENVIRONMENT === "production") {
  nowPosts = await getCollection("now", ({ data }) => !(data as { draft?: boolean }).draft);
} else {
  nowPosts = await getCollection("now");
}

nowPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const currentPost = nowPosts[0];
const pastPosts = nowPosts.slice(1);

function getExcerpt(body: string): string {
  const match = body.match(
    /##\s*Professional\s*\n([\s\S]*?)(?=\n##\s*Hobbies|$)/i,
  );
  const block = match?.[1]?.trim() ?? "";
  const plain = block
    .replace(/\n+/g, " ")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/[*_`#]/g, "")
    .trim();
  const first = plain.match(/^[^.!?]*[.!?]/)?.[0] ?? plain.slice(0, 120);
  return first.trim();
}

const cache = new Map<string, { data: unknown; expires: number }>();
const CACHE_TTL = 30000;

const apiKey = import.meta.env.LAST_FM_API_KEY;
const hardcoverToken = (import.meta.env.HARDCOVER_TOKEN ?? "").trim();

interface HardcoverMe {
  user_books: { book: { title: string; contributions: { author: { name: string } }[] } }[];
  lists?: Array<{
    books_count: number;
    list_books: Array<{
      user_books: Array<{ user_book_status: { slug: string } }>;
    }>;
  }>;
}

interface HardcoverResponse {
  data: { me: HardcoverMe[] };
}

function getCached(key: string): unknown {
  const cached = cache.get(key);
  if (cached && cached.expires > Date.now()) return cached.data;
  cache.delete(key);
  return null;
}

function setCached(key: string, data: unknown): void {
  cache.set(key, { data, expires: Date.now() + CACHE_TTL });
}

async function hardcoverGraphQL(
  query: string,
  variables: Record<string, unknown>,
  useAuth: boolean,
): Promise<HardcoverResponse> {
  if (useAuth && !hardcoverToken) {
    throw new Error(
      "hardcoverToken required. Get it from https://hardcover.app/account/api",
    );
  }
  const cacheKey = JSON.stringify({ query, variables });
  const cached = getCached(cacheKey);
  if (cached) return cached as HardcoverResponse;

  const headers: Record<string, string> = {
    "Content-Type": "application/json",
    "User-Agent": "dominickjay.com/1.0",
  };
  if (useAuth) {
    headers["authorization"] = hardcoverToken.startsWith("Bearer ")
      ? hardcoverToken
      : `Bearer ${hardcoverToken}`;
  }

  const response = await fetch("https://api.hardcover.app/v1/graphql", {
    method: "POST",
    headers,
    body: JSON.stringify({ query, variables }),
  });
  if (!response.ok) {
    throw new Error(`HTTP ${response.status}: ${await response.text()}`);
  }
  const json = (await response.json()) as HardcoverResponse;
  setCached(cacheKey, json);
  return json;
}

let currentlyReading: { book: { title: string; contributions: { author: { name: string } }[] } }[] = [];
let booksRead = 0;
let goalTotal = 0;

try {
  const currentDataAndList = await hardcoverGraphQL(
    `query getCurrentReadingAndList {
      me {
        user_books(where: { status_id: { _eq: 2 } }) {
          book {
            id
            title
            contributions { author { name } }
          }
        }
        lists(where: { id: { _eq: 328925 } }) {
          id
          name
          books_count
          list_books {
            book { id title contributions { author { name } } }
            user_books(where: { user_id: { _eq: 28090 } }, limit: 1, order_by: { updated_at: desc }) {
              user_book_status { status slug }
            }
          }
        }
      }
    }`,
    {},
    true,
  );
  const me = currentDataAndList.data?.me?.[0];
  if (me) {
    currentlyReading = me.user_books ?? [];
    const list = me.lists?.[0];
    if (list) {
      goalTotal = list.books_count ?? 0;
      const listBooks = list.list_books ?? [];
      booksRead = listBooks.filter(
        (lb: { user_books: { user_book_status: { slug: string } }[] }) =>
          lb.user_books?.[0]?.user_book_status?.slug === "read",
      ).length;
    }
  }
} catch (err) {
  console.error("[Now] Hardcover:", err);
}

let topTracks: { name: string; artist: { name?: string; "#text"?: string } }[] = [];
if (apiKey) {
  try {
    const res = await getTopTracks(apiKey, 10, "1month");
    if (res.toptracks?.track) topTracks = res.toptracks.track;
  } catch (err) {
    console.error("[Now] Last.fm:", err);
  }
}

let traktTitle: string | null = null;
let traktSeason: number | undefined;
let traktEpisode: number | undefined;

try {
  const tvCache = await sanityClient.fetch(`*[_id == "global-tv-cache"][0]{ tvJson }`);
  if (tvCache?.tvJson) {
    const parsed = JSON.parse(tvCache.tvJson) as {
      title?: string | null;
      season?: number;
      episode?: number;
    };
    traktTitle = parsed.title ?? null;
    traktSeason = parsed.season;
    traktEpisode = parsed.episode;
    console.log("[Now] Trakt Sanity fetch succeeded", { traktTitle, traktSeason, traktEpisode });
  }
} catch (err) {
  console.warn("[Now] Trakt Sanity fetch failed", err);
}

const lastUpdateFormatted = currentPost
  ? currentPost.data.pubDate.toLocaleDateString("en-GB", {
      month: "short",
      day: "numeric",
      year: "numeric",
    })
  : "";

const today = new Date().toISOString().slice(0, 10);

const currentRendered = currentPost
  ? await render(currentPost)
  : { Content: () => null };
const { Content: CurrentContent } = currentRendered;

const pastWithContent = await Promise.all(
  pastPosts.map(async (post) => {
    const { Content } = await render(post);
    const excerpt =
      (post.data as { excerpt?: string }).excerpt ?? getExcerpt(post.body ?? "");
    return { post, Content, excerpt };
  }),
);

const goalPercent =
  goalTotal > 0 ? Math.round((booksRead / goalTotal) * 100) : 0;
---

