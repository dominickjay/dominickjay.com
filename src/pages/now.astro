              </div>
              <div class="goal-bar__meta">
                <span>{booksRead} of {goalTotal} · 2026 goal</span>
                <span>{goalPercent}%</span>
              </div>
            </div>
          </div>
        </div>

        <div class="snap-card">
          <div class="snap-card__head">
            <span class="snap-card__label">Currently watching</span>
          </div>
          <div class="snap-card__body">
            {traktTitle ? (
              <div>
                <span class="watching-item__title">{traktTitle}</span>
                {(traktSeason != null || traktEpisode != null) && (
                  <span class="watching-item__meta">
                    {traktSeason != null && `Season ${traktSeason}`}
                    {traktSeason != null && traktEpisode != null && " · "}
                    {traktEpisode != null && `Episode ${traktEpisode}`}
                  </span>
                )}
              </div>
            ) : (
              <span class="watching-item__meta">Nothing yet</span>
            )}
          </div>
        </div>

        <div class="snap-card">
          <div class="snap-card__head">
            <span class="snap-card__label">Top tracks this month</span>
          </div>
          <div class="snap-card__body">
            <ol class="track-list">
              {topTracks.slice(0, 10).map((track, i) => (
                <li class="track-item">
                  <span class="track-item__name" title={track.name}>
                    {track.name}
                  </span>
                  <span class="track-item__artist">
                    {track.artist?.name ?? track.artist?.["#text"] ?? ""}
                  </span>
                </li>
              ))}
            </ol>
            {topTracks.length === 0 && (
              <span class="track-item__artist">No data</span>
            )}
          </div>
        </div>
      </aside>
       -->


      <div class="stacked prose now-snapshot" style="--gutter: var(--space-xl)">
       	<div class="stacked" style="--gutter: var(--space-m)">
       		<span class="eyebrow">
		        Currently reading
			    </span>
					<div
		         class="stacked"
		         style="--gutter: var(--space-m)"
		       >
				   	<div class="now-item stacked" style="--gutter: var(--space-m)">
			      	{currentlyReading.slice(0, 2).map((entry) => (
								<div class="stacked" style="--gutter: var(--space-s)">
						      <span class="title">{entry.book.title}</span>
						      <span class="author">
						        {entry.book.contributions?.[0]?.author?.name ?? ""}
						      </span>
								</div>
		          ))}
				   	</div>
						<div class="goal-bar">
              <div class="goal-bar__track">
                <div
                  class="goal-bar__fill"
                  style={`width: ${goalTotal > 0 ? (booksRead / goalTotal) * 100 : 0}%`}
                />
              </div>
              <div class="goal-bar__meta">
                <span>{booksRead} of {goalTotal} · 2026 goal</span>
