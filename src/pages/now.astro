                <line
                  x1="2"
                  y1="8"
                  x2="14"
                  y2="8"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                />
              </svg>
            </summary>
            <div class="past-entry__panel">
              <div class="past-entry__inner">
                <div class="past-entry__content">
                  <Content tracks={post.data.tracks} pubDate={today} />
                </div>
              </div>
            </div>
          </details>
        ))}
      </section>
    )}
  </article>
</Layout>
