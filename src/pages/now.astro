                <span class="title">{traktTitle}</span>
                {(traktSeason != null || traktEpisode != null) && (
                  <span class="meta">
                    {traktSeason != null && `Season ${traktSeason}`}
                    {traktSeason != null && traktEpisode != null && " · "}
                    {traktEpisode != null && `Episode ${traktEpisode}`}
                  </span>
                )}
              </div>
            ) : (
              <span class="watching-item__meta">Nothing yet</span>
            )}
          </div>
        </div>
        <div class="stacked" style="--gutter: var(--space-m)">
       		<span class="eyebrow">
         		Top tracks this month
			    </span>
					<div
		         class="stacked"
		         style="--gutter: var(--space-m)"
		      >
	      		<ol class="track-list">
              {topTracks.slice(0, 10).map((track, i) => (
                <li class="track-item">
                  <span class="track-item__name" title={track.name}>
                    {track.name}
                  </span>
                  <span class="track-item__artist">
                    {track.artist?.name ?? track.artist?.["#text"] ?? ""}
                  </span>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>
      <main class="now-written">
        {currentPost && CurrentContent && (
          <div class="now-written-content flow prose">
            <CurrentContent tracks={currentPost.data.tracks} pubDate={today} />
          </div>
        )}
      </main>
    </div>

    {pastPosts.length > 0 && (
      <section class="accordion-entries">
        <div class="accordion-entries__header">
          <span class="accordion-entries__title">Previous entries</span>
        </div>
        {pastWithContent.map(({ post, Content, excerpt }) => (
          <details class="past-entry">
