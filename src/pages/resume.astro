      		<div class="repel skills-list">
						<h3>Javascript</h3>
						<ul class="stacked">
							<li>Modern ES6+ syntax</li>
							<li>Working knowledge of AlpineJS and Vue</li>
							<li>Testing using Playwright.</li>
						</ul>
					</div>
       	</li>
        <li class="item">
      		<div class="repel skills-list">
						<h3>Soft Skills</h3>
						<ul class="stacked">
							<li>Excellent communication skills</li>
						</ul>
					</div>
       	</li>
      </ol>
    </section>
   	<Testimonials />
   	<section class="grid">
     	<h2>Education</h2>
