---
export const prerender = true;

import Layout from "../layouts/Default.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Picture } from "astro:assets";

---

<Layout
  {...{
    title: "Dom Jay — CSS, JS, and the occasional existential crisis",
    description:
      "Dom Jay's digital garden. CSS, JavaScript, and the web platform — written honestly, published impatiently, and updated whenever guilt kicks in.",
  } as any}
>
  <main>
  	<div class="container resume grid">
   		<header>
    		<div class="stacked">
	    		<h1 class="gradient-text">Dominick Jay</h1>
					<p>I'm a front-of-the-front-end developer with 10+ years of experience, with a strong focus on semantic HTML, modern CSS, and vanilla JavaScript. I'm drawn to open-source culture — building transparently, in collaboration with a community, and with a real sense of purpose behind the work.</p>
	      </div>
				<a href="mailto:hi@dominickjay.com">hi@dominickjay.com</a>
    	</header>
     	<section class="stacked">
      	<h2>Recent Full Time Experience</h2>
       	<div class="grid">
        	<div class="experience-card">
	       		<Picture
	           layout="full-width"
	           src="/images/companies/series-eight-logo.png"
	           formats={["avif", "webp"]}
	           alt="Logo for Series Eight"
	           loading="lazy"
	           height={25}
	           width={140}
	         />
        		<h3 class=""><span>Front End Developer </span> - Series Eight</h3>
        		<date>April 2022 - present</date>
          	<div class="">At Series Eight, I've worked with multiple CMS's - Shopify, CraftCMS and Webflow - providing award winning websites and user experiences. Most recently, I've been part of a specialised team to handle retained and ongoin clients - allowing for improved client relationships and improved processes.</div>
        	</div>
        	<div class="experience-card">
	         	<Picture
			        layout="full-width"
		          src="/images/companies/rowe-it-logo.png"
		          formats={["avif", "webp"]}
							alt="Logo for Rowe IT"
	          	loading="lazy"
	           	height={25}
		          width={140}
		         />
        		<h3 class=""><span>Software Engineer</span> - Rowe IT</h3>
        		<date>November 2019 - April 2022</date>
          	<div class="">At Rowe IT, I was part of multiple teams, conducting work using AWS Lambdas as well as conducting accessibility testing and improvements against the Met Office systems.</div>
        	</div>
        	<div class="experience-card">
        		<h3 class=""><span>Creative Developer</span> - GOSS Interactive</h3>
        		<date>April 2017 - November 2019</date>
          	<div class="">At GOSS Interactive, I worked on customising off-the-shelf themes for councils across the country, conducting client training via in-person, audio and video meetings. Also supported clients with more bespoke solutions as part of a developer support team.</div>
        	</div>
        	<div class="experience-card">
        		<h3 class=""><span>Junior Web Developer</span> - n9Design</h3>
        		<date>June 2016 - March 2017</date>
        	</div>
        	<div class="experience-card">
        		<h3 class=""><span>Junior Web Developer</span> - Logo Design</h3>
        		<date>August 2015 - May 2016</date>
        	</div>
        </div>
      </section>
     	<section class="stacked">
      	<h2>Relevant Experience</h2>
	      <div class="grid">
					<div class="stacked skills-list">
						<h3>HTML</h3>
						<ul class="stacked">
							<li>Semantic document structure and SEO optimization.</li>
							<li>Advanced Webflow CMS architecture and data modeling.</li>
							<li>Custom attributes and DOM manipulation for extended functionality.</li>
						</ul>
					</div>
					<div class="stacked skills-list">
						<h3>CSS</h3>
						<ul class="stacked">
							<li>Implementation of scalable systems (Client-First, BEM, or Finsweet).</li>
							<li>Modern feature sets including CSS Grid, Flexbox, and Custom Properties.</li>
							<li>Performant interaction design and complex web animations.</li>
							<li>Responsive, fluid typography and layout systems.</li>
						</ul>
					</div>
					<div class="stacked skills-list">
						<h3>Javascript</h3>
						<ul class="stacked">
							<li>Modern ES6+ syntax</li>
							<li>Working knowledge of AlpineJS and Vue</li>
							<li>Testing using Playwright.</li>
						</ul>
					</div>
					<div class="stacked skills-list">
						<h3>Accessibility</h3>
						<ul class="stacked">
							<li>Semantic document structure and SEO optimization.</li>
							<li>Semantic document structure and SEO optimization.</li>
							<li>Semantic document structure and SEO optimization.</li>
						</ul>
					</div>
				</div>
      </section>
   	</div>
  </main>
</Layout>
