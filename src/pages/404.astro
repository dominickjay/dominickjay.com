function levenshteinDistance(a, b) {
  a = a.toLowerCase();
  b = b.toLowerCase();

  const distances = Array.from({ length: b.length + 1 }, (_, i) => i);

  for (let aIndex = 1; aIndex <= a.length; aIndex++) {
    let previousDistance = aIndex;
    distances[0] = aIndex;

    for (let bIndex = 1; bIndex <= b.length; bIndex++) {
      const oldDistance = distances[bIndex];
      const cost = a[aIndex - 1] === b[bIndex - 1] ? 0 : 1;

      distances[bIndex] = Math.min(
        distances[bIndex] + 1,
        distances[bIndex - 1] + 1,
        previousDistance + cost,
      );

      previousDistance = oldDistance;
    }
  }

  return distances[b.length];
}

