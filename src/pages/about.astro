---
import Layout from "../layouts/Default.astro";
import Profile from "../components/Profile.astro";
import Testimonials from "../components/Testimonials.astro";
import MarqueeHeading from "../components/MarqueeHeading.astro";
import ScrollHeading from "../components/ScrollHeading.astro";
import { ABOUT_INTRO, ABOUT_CONTENT, ABOUT_COMPANIES } from "../consts";
import BigLink from "../components/BigLink.astro";
import FormattedDate from "../components/FormattedDate.astro";

const showMarquee = true;
const contentIntro = ABOUT_INTRO.medium
  .replaceAll("[", '<span class="current-job">')
  .replaceAll("]", "</span>");

const companies = ABOUT_COMPANIES;
---

{/* @ts-ignore */}
<Layout
  {...{
    title: "A bit about me",
    description: "I'm Dom Jay — a developer and writer based in the UK. I write about CSS, JavaScript, and the messy reality of working on the web.",
    pubDate: new Date("August 08 2021"),
    tags: [],
    headings: [],
    timeToRead: 0,
  } as any}
>
  <div class="about flow">
    <div
      class="grid grid-cols-6 container"
      style="--grid-placement: 6; --gutter: 43px;"
    >
      <div class="col-span-full md:col-span-2">
        <Profile sticky={true} />
      </div>
      <div class="col-span-full md:col-span-4 flow">
        <div class="flow">
          <div class="overflow-clip">
            {showMarquee && <MarqueeHeading title="About" />}
            {!showMarquee && <ScrollHeading title="About" />}
          </div>
          <h2 class="h2" set:html={contentIntro} />
          <div
            class="intro flow [--flow-space:var(--space-s)] pt-[var(--space-l)] prose"
          >
            <p>
              I am a Front-End Developer currently based in the UK, working with
              the team at <a href="https://serieseight.com/">Series Eight</a>.
              My work sits at the intersection of accessibility, user
              experience, and creative experimentation.
            </p>
          </div>
          <div
            class="flow [--flow-space:var(--space-s)] pt-[var(--space-m)] prose"
          >
            <h3>Professional</h3>
            <p>
            I build performant, accessible websites for a living - mostly with Tailwind, Alpine, CraftCMS and Shopify, which sounds less exciting than it is. I've spent time across design agencies and the private sector over the years, which has given me a fairly good radar for when something is being built right and when it's being built fast. Currently at <i class="font-semibold">Series Eight</i>, where the answer is usually both.
            </p>
          </div>
          <div class="flow [--flow-space:var(--space-s)] prose">
            <h3>This Site</h3>
            <p>
              I treat this corner of the internet as a digital playground. It’s
              a space where I can break things, try out new CSS techniques, and
              document what I’m learning. Whether it’s a small project on
              CodePen or a deep dive on my blog, this site is a living
              reflection of my professional and personal evolution.
            </p>
          </div>
          <div class="flow [--flow-space:var(--space-s)] prose">
            <h3 class="h3">Personal Interests</h3>
            <p>
            		I write code for a living and genuinely enjoy it - it's just not my whole personality. Outside of work I'm a parent of two, a serious drummer, an enthusiastic D&D player, and someone still figuring out how to stay on a longboard when the opportunity arises. I also play guitar and ukulele, read more books than I finish, and have strong opinions about music that nobody asked for.
            </p>
            <p>
              You can usually find me <a href="/books"
                >reading a new book</a
              > or sharing my latest <a href="/now">"Now" updates.</a>
            </p>
          </div>
          <div class="flow [--flow-space:var(--space-s)] prose">
            <p>
              <ol class="post-list feature-list flow" style="--flow-space: 0;">
                {
                  companies.map((company, i) => {
                    let { jobTitle, label, date } = company;
                    return (
                      <li class="post-item visible">
                        <div class="post-info post-info--small">
                          <span class="post-n min-w-[110px]">{date}</span>
                          <div class="post-body">
                            <span class="post-title">{jobTitle}</span>
                            <div class="post-meta">
                              <span class="post-topics-label">{label}</span>
                            </div>
                          </div>
                        </div>
                      </li>
                    );
                  })
                }
              </ol>
            </p>
            <BigLink text="View my resume." href="/resume.pdf" />
          </div>
          <div>
            <Testimonials />
          </div>

          <!-- <Companies /> -->
        </div>
      </div>
    </div>
  </div>
</Layout>
